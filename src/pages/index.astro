  <script>
    // Nav scroll
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // Story canvas crossfade
    const BASE = 'https://berrybloom.ewr1.vultrobjects.com/assets/';
    const frames = ['f1-seed', 'f2-sapling', 'f3-fulltree', 'f4-wind', 'f5-petals', 'blossom-final'];
    const layerA = document.getElementById('canvas-a');
    const layerB = document.getElementById('canvas-b');
    let active = 'a';
    let currentFrame = -1;

    // Preload all frames
    frames.forEach(f => { const img = new Image(); img.src = `${BASE}${f}.png`; });

    function setFrame(index) {
      if (index === currentFrame) return;
      currentFrame = index;
      const url = `url(${BASE}${frames[index]}.png) center center / cover no-repeat`;
      if (active === 'a') {
        layerB.style.background = url;
        layerA.style.opacity = '0';
        layerB.style.opacity = '1';
        active = 'b';
      } else {
        layerA.style.background = url;
        layerB.style.opacity = '0';
        layerA.style.opacity = '1';
        active = 'a';
      }
    }

    // Set seed frame immediately
    layerA.style.background = `url(${BASE}${frames[0]}.png) center center / cover no-repeat`;

    // Map sections → frames
    const storyMap = [
      { id: 'home',     frame: 0 }, // Planting the seed
      { id: 'services', frame: 1 }, // Growth
      { id: 'quote',    frame: 2 }, // Bloom
      { id: 'why',      frame: 3 }, // Expand to the wind
      { id: 'process',  frame: 3 }, // Still wind
      { id: 'contact',  frame: 4 }, // Petals
    ];

    const frameObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const match = storyMap.find(m => m.id === entry.target.id);
          if (match) setFrame(match.frame);
        }
      });
    }, { threshold: 0.25 });

    storyMap.forEach(({ id }) => {
      const el = document.getElementById(id);
      if (el) frameObserver.observe(el);
    });

    // Reveal on scroll
    const reveals = document.querySelectorAll('.reveal');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    reveals.forEach(el => revealObserver.observe(el));
  </script>

