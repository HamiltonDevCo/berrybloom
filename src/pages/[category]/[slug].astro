---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { category: post.data.category, slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, category, ogImage, noindex } = post.data;
---
<Base
  title={`${title} — BerryBloom Agency`}
  description={description}
  ogImage={ogImage}
  ogType="article"
  noindex={noindex}
>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --pink: #ff3374; --black: #0d0d0d; --off-white: #f7f6f4; --white: #ffffff; }
    body { font-family: 'DM Sans', -apple-system, sans-serif; background: var(--off-white); color: var(--black); -webkit-font-smoothing: antialiased; }
    nav { background: var(--black); padding: 20px 48px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { font-family: 'Red Hat Display', sans-serif; font-weight: 700; font-size: 1.1rem; color: white; text-decoration: none; }
    .nav-logo span { color: var(--pink); }
    .nav-back { font-size: 0.85rem; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-back:hover { color: white; }
    .hero { background: var(--black); padding: 72px 48px 56px; }
    .hero-cat { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--pink); margin-bottom: 16px; }
    h1 { font-family: 'Red Hat Display', sans-serif; font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 900; letter-spacing: -0.03em; color: white; max-width: 760px; line-height: 1.1; }
    .hero-meta { margin-top: 20px; font-size: 0.8rem; color: rgba(255,255,255,0.4); }
    .article-wrap { max-width: 760px; margin: 0 auto; padding: 56px 48px 80px; }
    .prose { font-size: 1rem; line-height: 1.8; color: #333; font-weight: 300; }
    .prose h2 { font-family: 'Red Hat Display', sans-serif; font-size: 1.5rem; font-weight: 800; letter-spacing: -0.02em; margin: 2.5rem 0 1rem; color: var(--black); }
    .prose h3 { font-family: 'Red Hat Display', sans-serif; font-size: 1.15rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--black); }
    .prose p { margin-bottom: 1.25rem; }
    .prose ul, .prose ol { margin: 1rem 0 1.25rem 1.5rem; }
    .prose li { margin-bottom: 0.4rem; }
    .prose strong { font-weight: 600; color: var(--black); }
    .prose a { color: var(--pink); text-decoration: none; border-bottom: 1px solid rgba(255,51,116,0.3); transition: border-color 0.2s; }
    .prose a:hover { border-color: var(--pink); }
    .cta-box { background: var(--black); border-radius: 8px; padding: 40px; margin: 48px 0 0; }
    .cta-box h3 { font-family: 'Red Hat Display', sans-serif; font-size: 1.4rem; font-weight: 800; color: white; margin-bottom: 12px; letter-spacing: -0.02em; }
    .cta-box p { font-size: 0.9rem; color: rgba(255,255,255,0.55); margin-bottom: 24px; font-weight: 300; }
    .cta-btn { display: inline-block; background: var(--pink); color: white; padding: 14px 28px; border-radius: 4px; font-family: 'Red Hat Display', sans-serif; font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: opacity 0.2s; }
    .cta-btn:hover { opacity: 0.88; }
    footer { background: var(--black); padding: 32px 48px; text-align: center; border-top: 1px solid rgba(255,255,255,0.06); }
    footer p { font-size: 0.78rem; color: rgba(255,255,255,0.3); }
    @media (max-width: 768px) {
      nav { padding: 18px 24px; }
      .hero { padding: 56px 24px 40px; }
      .article-wrap { padding: 40px 24px 60px; }
    }
  </style>

  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": pubDate.toISOString(),
      "dateModified": (updatedDate || pubDate).toISOString(),
      "author": { "@type": "Organization", "name": "BerryBloom Agency" },
      "publisher": {
        "@type": "Organization",
        "name": "BerryBloom Agency",
        "url": "https://berrybloom.agency"
      }
    })}
  </script>

  <nav>
    <a href="/" class="nav-logo">Berry<span>Bloom</span></a>
    <a href="/blog/" class="nav-back">← All posts</a>
  </nav>

  <div class="hero">
    <p class="hero-cat">{category.replace(/-/g, ' ')}</p>
    <h1>{title}</h1>
    <p class="hero-meta">
      {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      {updatedDate && ` · Updated ${updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}`}
    </p>
  </div>

  <div class="article-wrap">
    <div class="prose">
      <Content />
    </div>

    <div class="cta-box">
      <h3>Ready to grow your business?</h3>
      <p>Let's have a real conversation about what's getting in the way — and how we fix it.</p>
      <a href="/book-appointment/" class="cta-btn">Schedule a call →</a>
    </div>
  </div>

  <footer>
    <p>© {new Date().getFullYear()} BerryBloom Agency · <a href="/" style="color:rgba(255,255,255,0.4);text-decoration:none;">berrybloom.agency</a></p>
  </footer>
</Base>
