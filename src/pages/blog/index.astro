---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.noindex)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base
  title="Marketing Insights — BerryBloom Agency"
  description="Practical marketing advice for businesses that want to grow. Web development, SEO, content strategy, and digital marketing from BerryBloom Agency."
>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --pink: #ff3374;
      --black: #0d0d0d;
      --charcoal: #1a1a1a;
      --off-white: #f7f6f4;
      --white: #ffffff;
    }
    body { font-family: 'DM Sans', -apple-system, sans-serif; background: var(--off-white); color: var(--black); -webkit-font-smoothing: antialiased; }
    nav {
      background: var(--black);
      padding: 20px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo { font-family: 'Red Hat Display', sans-serif; font-weight: 700; font-size: 1.1rem; color: white; text-decoration: none; }
    .nav-logo span { color: var(--pink); }
    .nav-back { font-size: 0.85rem; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
    .nav-back:hover { color: white; }
    .hero { background: var(--black); padding: 80px 48px 64px; }
    .hero-label { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--pink); margin-bottom: 16px; }
    h1 { font-family: 'Red Hat Display', sans-serif; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; letter-spacing: -0.03em; color: white; max-width: 700px; }
    .content { max-width: 1200px; margin: 0 auto; padding: 64px 48px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
    .card { background: white; border-radius: 6px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }
    .card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.08); }
    .card a { text-decoration: none; color: inherit; }
    .card-body { padding: 28px 28px 24px; }
    .card-cat { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pink); margin-bottom: 12px; }
    .card-title { font-family: 'Red Hat Display', sans-serif; font-size: 1.15rem; font-weight: 800; letter-spacing: -0.01em; line-height: 1.3; margin-bottom: 10px; }
    .card-desc { font-size: 0.88rem; color: #666; line-height: 1.6; font-weight: 300; }
    .card-date { padding: 0 28px 20px; font-size: 0.75rem; color: #aaa; }
    footer { background: var(--black); padding: 32px 48px; text-align: center; }
    footer p { font-size: 0.78rem; color: rgba(255,255,255,0.3); }
    @media (max-width: 768px) {
      nav, .hero { padding-left: 24px; padding-right: 24px; }
      .content { padding: 40px 24px; }
    }
  </style>

  <nav>
    <a href="/" class="nav-logo">Berry<span>Bloom</span></a>
    <a href="/" class="nav-back">← Back to site</a>
  </nav>

  <div class="hero">
    <p class="hero-label">Marketing Insights</p>
    <h1>Practical advice.<br>No fluff.</h1>
  </div>

  <div class="content">
    <div class="grid">
      {posts.map(post => (
        <article class="card">
          <a href={`/${post.data.category}/${post.id}/`}>
            <div class="card-body">
              <p class="card-cat">{post.data.category.replace(/-/g, ' ')}</p>
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-desc">{post.data.description}</p>
            </div>
            <p class="card-date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
          </a>
        </article>
      ))}
    </div>
  </div>

  <footer>
    <p>© {new Date().getFullYear()} BerryBloom Agency · Bardstown, KY</p>
  </footer>
</Base>
